            <column caption='Revenue per Hour' datatype='real' name='[Calculation_3474330263928838]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([total_amount]) / (SUM([trip_duration]) / 60)' />
            </column>
            <column-instance column='[borough]' derivation='Attribute' name='[attr:borough:nk]' pivot='key' type='nominal' />
            <column-instance column='[speed_mph]' derivation='Avg' name='[avg:speed_mph:qk]' pivot='key' type='quantitative' />
