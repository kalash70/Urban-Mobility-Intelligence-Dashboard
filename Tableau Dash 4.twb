      <aliases enabled='yes' />
      <column caption='Airport fee' datatype='real' name='[Airport_fee]' role='measure' type='quantitative' />
      <column caption='Calculation1' datatype='real' name='[Calculation_3244532291739653]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([total_amount]) - LOOKUP(SUM([total_amount]), -12)) / ABS(LOOKUP(SUM([total_amount]), -12))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Rate Code Label' datatype='string' name='[Calculation_3474330253049859]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [RatecodeID] = 1 THEN &quot;Standard Metered&quot;&#10;ELSEIF [RatecodeID] = 2 THEN &quot;JFK Flat Rate&quot;&#10;ELSEIF [RatecodeID] = 3 THEN &quot;Newark&quot;&#10;ELSEIF [RatecodeID] = 4 THEN &quot;Nassau/Westchester&quot;&#10;ELSEIF [RatecodeID] = 5 THEN &quot;Negotiated Fare&quot;&#10;ELSEIF [RatecodeID] = 6 THEN &quot;Group Ride&quot;&#10;ELSE &quot;Unknown&quot;&#10;END' />
      </column>
      <column caption='Payment T' datatype='string' name='[Calculation_3474330257793028]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [payment_type] = 1 THEN &quot;Credit Card&quot;&#10;ELSEIF [payment_type] = 2 THEN &quot;Cash&quot;&#10;ELSEIF [payment_type] = 3 THEN &quot;No Charge&quot;&#10;ELSEIF [payment_type] = 4 THEN &quot;Dispute&quot;&#10;ELSE &quot;Unknown&quot;&#10;END' />
      </column>
      <column caption='Congestion Level' datatype='string' name='[Calculation_3474330263465989]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([speed_mph]) &lt; 10 THEN &quot;Severe&quot;&#10;ELSEIF AVG([speed_mph]) &lt; 15 THEN &quot;Moderate&quot;&#10;ELSEIF AVG([speed_mph]) &lt; 20 THEN &quot;Light&quot;&#10;ELSE &quot;Free Flow&quot;&#10;END' />
      </column>
      <column caption='Revenue per Hour' datatype='real' name='[Calculation_3474330263928838]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_amount]) / (SUM([trip_duration]) / 60)' />
      </column>
      <column caption='Dispute Rate' datatype='real' name='[Calculation_3474330271576071]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [payment_type] = 4 THEN 1 ELSE 0 END) / COUNT([tpep_pickup_datetime])' />
      </column>
      <column caption='No Charge Rate' datatype='real' name='[Calculation_3474330271727624]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [payment_type] = 3 THEN 1 ELSE 0 END) / COUNT([tpep_pickup_datetime])' />
      </column>
      <column caption='DO Location ID' datatype='integer' name='[DOLocationID]' role='dimension' type='ordinal' />
      <column caption='Geometry (geo export 397045d7-e5d7-4e49-a48a-d39eab0e5379.shp1)' datatype='spatial' name='[Geometry (geo_export_397045d7-e5d7-4e49-a48a-d39eab0e5379.shp1)]' role='measure' type='nominal' />
      <column caption='PU Location ID' datatype='integer' name='[PULocationID]' role='dimension' type='ordinal' />
