      <layout dim-ordering='alphabetic' measure-ordering='alphabetic' show-structure='true' />
      <style>
        <style-rule element='mark'>
          <encoding attr='color' field='[yr:tpep_pickup_datetime:ok]' type='palette'>
            <map to='#4e79a7'>
              <bucket>%null%</bucket>
            </map>
            <map to='#76b7b2'>
              <bucket>2026</bucket>
            </map>
            <map to='#e15759'>
              <bucket>2025</bucket>
            </map>
            <map to='#f28e2b'>
              <bucket>2009</bucket>
            </map>
          </encoding>
          <encoding attr='color' field='[none:borough:nk]' type='palette'>
            <map to='#4e79a7'>
              <bucket>&quot;Manhattan&quot;</bucket>
            </map>
            <map to='#59a14f'>
              <bucket>&quot;Brooklyn&quot;</bucket>
            </map>
            <map to='#76b7b2'>
              <bucket>&quot;Bronx&quot;</bucket>
            </map>
            <map to='#b07aa1'>
              <bucket>&quot;Staten Island&quot;</bucket>
            </map>
            <map to='#e15759'>
              <bucket>%null%</bucket>
            </map>
            <map to='#edc948'>
              <bucket>&quot;EWR&quot;</bucket>
            </map>
            <map to='#f28e2b'>
              <bucket>&quot;Queens&quot;</bucket>
            </map>
          </encoding>
          <encoding attr='color' field='[none:is_peak:nk]' palette='gray_10_0' type='palette'>
            <map to='#49525e'>
              <bucket>true</bucket>
            </map>
            <map to='#d5d5d5'>
              <bucket>false</bucket>
            </map>
          </encoding>
          <encoding attr='color' field='[mn:tpep_pickup_datetime:ok]' type='palette'>
            <map to='#4e79a7'>
              <bucket>%null%</bucket>
            </map>
            <map to='#76b7b2'>
              <bucket>2026</bucket>
            </map>
            <map to='#e15759'>
              <bucket>2025</bucket>
            </map>
            <map to='#f28e2b'>
              <bucket>2009</bucket>
            </map>
          </encoding>
          <encoding attr='color' field='[none:is_weekend:nk]' type='palette'>
            <map to='#4e79a7'>
              <bucket>false</bucket>
            </map>
            <map to='#f28e2b'>
              <bucket>true</bucket>
            </map>
          </encoding>
        </style-rule>
      </style>
